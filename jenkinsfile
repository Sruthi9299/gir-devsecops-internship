pipeline {
    agent any
    stages {
        stage('Checkout') {
            steps { git 'https://github.com/Sruthi9299/gir-devsecops-internship.git' }
        }
        stage('Build') {
            steps { sh 'mvn clean package' }
        }
        stage('Test') {
            steps { sh 'mvn test' }
        }
        stage('Docker Build') {
            steps { sh 'docker build -t santisruthi/ci-cd-demo:latest .' }
        }
        stage('Push to DockerHub') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'dockerhub-creds', usernameVariable: 'USER', passwordVariable: 'PASS')]) {
                    sh 'echo $PASS | docker login -u $USER --password-stdin'
                    sh 'docker push yourdockerhub/ci-cd-demo:latest'
                }
            }
        }
    }
}
